        scroll {
            bindings = <LAYER_ADAPTER(
___,            ___,            ___,            ___,            ___,            ___,                    ___,            ___,            ___,            ___,            ___,            ___,
___,            ___,            ___,            ___,            ___,            ___,                    ___,            ___,            ___,            ___,            ___,            ___,
___,            ___,            ___,            ___,            ___,            ___,                    ___,            ___,            ___,            ___,            ___,            ___,
___,            ___,            ___,            ___,            ___,            ___,                    ___,            ___,            ___,            ___,            ___,            ___,
___,            ___,            ___,            ___,            ___,            ___,                    ___,            ___,            ___,            ___,            ___,            ___,
___,            ___,            ___,            ___,            ___,            ___,                    ___,            ___,            ___,            ___,            ___,            ___
            )>;
        };

        snipe {
            bindings = <LAYER_ADAPTER(
___,            ___,            ___,            ___,            ___,            ___,                    ___,            ___,            ___,            ___,            ___,            ___,
___,            ___,            ___,            ___,            ___,            ___,                    ___,            ___,            ___,            ___,            ___,            ___,
___,            ___,            &mkp MCLK,      &mkp LCLK,      &mkp RCLK,      ___,                    ___,            ___,            ___,            ___,            ___,            ___,
___,            ___,            ___,            ___,            ___,            ___,                    ___,            ___,            ___,            ___,            ___,            ___,
___,            ___,            ___,            ___,            ___,            ___,                    ___,            ___,            ___,            ___,            ___,            ___,
___,            ___,            ___,            ___,            ___,            ___,                    ___,            ___,            ___,            ___,            ___,            ___
            )>;
        };

        automouse {
            bindings = <LAYER_ADAPTER(
___,            ___,            ___,            ___,            ___,            ___,                    ___,            ___,            ___,            ___,            ___,            ___,
___,            ___,            ___,            ___,            ___,            ___,                    ___,            ___,            ___,            ___,            ___,            ___,
___,            ___,            &mkp MCLK,      &mkp LCLK,      &mkp RCLK,      ___,                    ___,            ___,            ___,            ___,            ___,            ___,
___,            ___,            ___,            ___,            ___,            ___,                    ___,            ___,            ___,            ___,            ___,            ___,
___,            ___,            ___,            ___,            ___,            ___,                    ___,            ___,            ___,            ___,            ___,            ___,
___,            ___,            ___,            ___,            ___,            ___,                    ___,            ___,            ___,            ___,            ___,            ___
            )>;
        };
    };
};

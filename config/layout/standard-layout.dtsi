        num {
            bindings = <LAYER_ADAPTER(
XXX,            XXX,            XXX,            XXX,            XXX,            XXX,                    XXX,           XXX,            XXX,            XXX,            XXX,           XXX,
XXX,            &mo SCROLL,     &mkp MCLK,      &mkp LCLK,      &mkp RCLK,      XXX,                    &kp LBKT,      &kp N7,         &kp N8,         &kp N9,         &kp RBKT,      XXX,
XXX,            &kp LGUI,       &kp LALT,       &kp LCTRL,      &kp LSHFT,      XXX,                    &kp EQUAL,     &kp N4,         &kp N5,         &kp N6,         &kp SEMI,      XXX,
XXX,            &kp LC(Z),      &kp LC(X),      &kp LC(C),      &kp LC(V),      &kp LC(Y),              &kp BSLH,      &kp N1,         &kp N2,         &kp N3,         &kp GRAVE,     XXX,
XXX,            XXX,            XXX,            ___,            ___,            ___,                    &kp MINUS,     &kp N0,         XXX,            XXX,            XXX,           XXX,
XXX,            XXX,            XXX,            XXX,            ___,            ___,                    XXX,           XXX,            XXX,            XXX,            XXX,           XXX
            )>;
        };

        sym {
            bindings = <LAYER_ADAPTER(
XXX,            XXX,            XXX,            XXX,            XXX,            XXX,                    XXX,            XXX,            XXX,            XXX,            XXX,            XXX,
XXX,            XXX,            XXX,            XXX,            XXX,            XXX,                    &kp LBRC,       &kp AMPS,       &kp ASTRK,      &kp LPAR,       &kp RBRC,       XXX,
XXX,            &kp LGUI,       &kp LALT,       &kp LCTRL,      &kp LSHFT,      XXX,                    &kp PLUS,       &kp DLLR,       &kp PRCNT,      &kp CARET,      &kp COLON,      XXX,
XXX,            XXX,            XXX,            &kp LG(SPACE),  &kp LC(SPACE),  &kp LA(Z),              &kp PIPE,       &kp EXCL,       &kp AT,         &kp HASH,       &kp TILDE,      XXX,
XXX,            XXX,            XXX,            ___,            ___,            ___,                    &kp UNDER,      &kp DOT,        XXX,            XXX,            XXX,            XXX,
XXX,            XXX,            XXX,            XXX,            ___,            ___,                    XXX,            XXX,            XXX,            XXX,            XXX,            XXX
            )>;
        };

        fn {
            bindings = <LAYER_ADAPTER(
XXX,             XXX,            XXX,            XXX,            XXX,           XXX,                    XXX,            XXX,            XXX,            XXX,            XXX,            XXX,
XXX,             XXX,            XXX,            XXX,            XXX,           XXX,                    &kp LPAR,       &kp F7,         &kp F8,         &kp F9,         &kp RPAR,       XXX,
XXX,             &kp LGUI,       &kp LALT,       &kp LCTRL,      &kp LSHFT,     XXX,                    &kp F12,        &kp F4,         &kp F5,         &kp F6,         &kp F11,        XXX,
XXX,             XXX,            XXX,            XXX,            XXX,           XXX,                    &kp SLCK,       &kp F1,         &kp F2,         &kp F3,         &kp F10,        XXX,
XXX,             XXX,            XXX,            ___,            ___,           ___,                    &kp TAB,        &kp SPACE,      XXX,            XXX,            XXX,            XXX,
XXX,             XXX,            XXX,            XXX,            ___,           ___,                    XXX,            XXX,            XXX,            XXX,            XXX,            XXX
            )>;
        };

        vanilla {
            bindings = <LAYER_ADAPTER(
&kp TILDE,      &kp 1,          &kp 2,          &kp 3,          &kp 4,          &kp 5,                  &kp 6,          &kp 7,          &kp 8,          &kp 9,          &kp 0,          &kp BSPC,
&kp LSHFT,      &kp Q,          &kp W,          &kp E,          &kp R,          &kp T,                  &kp Y,          &kp U,          &kp I,          &kp O,          &kp SQT,        &kp DEL,
&kp LALT,       &kp A,          &kp S,          &kp D,          &kp F,          &kp G,                  &kp H,          &hm RSHIFT J,   &hm LCTRL K,    &hm LALT L,     &hm LGUI P,     XXX,
&kp LCTRL,      &kp Z,          &kp X,          &kp C,          &kp V,          &kp B,                  &kp N,          &kp M,          &kp COMMA,      &kp DOT,        &kp FSLH,       XXX,
XXX,            XXX,            XXX,            &lt FN ESC,     &kp SPACE,      &kp TAB,                &kp RET,        &kp BSPC,       XXX,            XXX,            XXX,            XXX,
XXX,            XXX,            XXX,            XXX,            ___,            ___,                    XXX,            XXX,            XXX,            XXX,            XXX,            XXX
            )>;
        };

        sys {
            bindings = <LAYER_ADAPTER(
XXX,            XXX,            XXX,            XXX,            XXX,            XXX,                    XXX,            XXX,            XXX,            XXX,            XXX,            XXX,
XXX,            &bt BT_SEL 0,   &bt BT_SEL 1,   &bt BT_SEL 2,   &bt BT_SEL 3,   &bt BT_SEL 4,           &to 0,          &to 1,          &to 8,          XXX,            XXX,            XXX,
XXX,            &bt BT_CLR_ALL, XXX,            XXX,            XXX,            &bootloader,            &bootloader,    XXX,            XXX,            XXX,            XXX,            XXX,
XXX,            &bt BT_CLR,     &out OUT_BLE,   &out OUT_USB,   &sys_reset,     &soft_off,              &soft_off,      &sys_reset,     XXX,            XXX,            XXX,            XXX,
XXX,            XXX,            XXX,            XXX,            XXX,            XXX,                    XXX,            XXX,            XXX,            XXX,            XXX,            XXX,
XXX,            XXX,            XXX,            XXX,            XXX,            XXX,                    XXX,            XXX,            XXX,            XXX,            XXX,            XXX
            )>;
